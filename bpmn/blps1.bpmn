<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_PenaltyClaims" targetNamespace="http://example.com/bpmn/penalty-claims" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:process id="PenaltyClaimProcess" name="Сервис заявок на штрафные санкции" isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Client" name="Заявитель (арендодатель)">
        <bpmn:flowNodeRef>StartEvent_RequestCreated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_CreateClaim</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ProvideDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IntermediateThrowEvent_NotifyDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_PenaltyApplied</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ClaimRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Platform" name="Платформа (Airbnb Support)">
        <bpmn:flowNodeRef>ExclusiveGateway_EnoughData</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ExclusiveGateway_RulesViolated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_SupportReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ExclusiveGateway_ApprovePenalty</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0gw4i7b</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1p30r0x</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_ApplyPenalty</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_CloseWithoutPenalty</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Respondent" name="Ответчик (арендартор)">
        <bpmn:flowNodeRef>IntermediateThrowEvent_RequestComment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_RespondComment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryTimer_ResponseTimeout</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_RequestCreated" name="Заявка инициирована" />
    <bpmn:userTask id="UserTask_CreateClaim" name="Создать заявку на возмещение ущерба (санкции)" camunda:assignee="${initiator}">
      <bpmn:documentation>Заявитель заполняет форму, указывает инцидент, сумму/тип штрафа, прикладывает доказательства.</bpmn:documentation>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="ExclusiveGateway_EnoughData" name="Данных достаточно?">
      <bpmn:incoming>Flow_1mbnhfb</bpmn:incoming>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UserTask_ProvideDocs" name="Запросить доп. материалы у заявителя" camunda:assignee="${initiator}">
      <bpmn:documentation>Если данных недостаточно — запросить уточнение / дополнительные документы.</bpmn:documentation>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="ExclusiveGateway_RulesViolated" name="Есть основания для штрафа?">
      <bpmn:incoming>Flow_065q47c</bpmn:incoming>
    </bpmn:exclusiveGateway>
    <bpmn:intermediateThrowEvent id="IntermediateThrowEvent_RequestComment" name="Запросить комментарий ответчика">
      <bpmn:messageEventDefinition id="MessageEventDefinition_RequestComment" />
    </bpmn:intermediateThrowEvent>
    <bpmn:userTask id="UserTask_RespondComment" name="Ответчик предоставляет комментарий / возражение / соглашается" camunda:assignee="${respondent}">
      <bpmn:documentation>Ответчик прикладывает объяснение и документы. При отсутствии ответа процесс идет дальше по таймауту.</bpmn:documentation>
      <bpmn:outgoing>Flow_0cyfudy</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_SupportReview" name="Ручная проверка специалистом поддержки" camunda:candidateGroups="support,risk-team">
      <bpmn:documentation>Специалист анализирует материалы сторон, результаты автопроверки и принимает решение.</bpmn:documentation>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="ExclusiveGateway_ApprovePenalty" name="Штраф подтвержден?" />
    <bpmn:serviceTask id="ServiceTask_ApplyPenalty" name="Применить штраф / удержание / блокировку" camunda:type="external" camunda:topic="apply-penalty">
      <bpmn:documentation>Применение санкции: удержание, списание, блокировка, предупреждение, запись в историю нарушений.</bpmn:documentation>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_CloseWithoutPenalty" name="Закрыть заявку без штрафа" camunda:type="external" camunda:topic="close-claim">
      <bpmn:documentation>Закрытие заявки с фиксацией причины отказа.</bpmn:documentation>
    </bpmn:serviceTask>
    <bpmn:intermediateThrowEvent id="IntermediateThrowEvent_NotifyDecision" name="Уведомить стороны о решении">
      <bpmn:messageEventDefinition id="MessageEventDefinition_NotifyDecision" />
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="EndEvent_PenaltyApplied" name="Штраф применен" />
    <bpmn:endEvent id="EndEvent_ClaimRejected" name="В штрафе отказано" />
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_RequestCreated" targetRef="UserTask_CreateClaim" />
    <bpmn:sequenceFlow id="Flow_04_yes" sourceRef="ExclusiveGateway_EnoughData" targetRef="Activity_0gw4i7b">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${enoughData == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_04_no" name="" sourceRef="ExclusiveGateway_EnoughData" targetRef="UserTask_ProvideDocs">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${enoughData == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_07_yes" sourceRef="ExclusiveGateway_RulesViolated" targetRef="IntermediateThrowEvent_RequestComment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${groundsForPenalty == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_07_no" sourceRef="ExclusiveGateway_RulesViolated" targetRef="ServiceTask_CloseWithoutPenalty">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${groundsForPenalty == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_08" sourceRef="IntermediateThrowEvent_RequestComment" targetRef="UserTask_RespondComment" />
    <bpmn:sequenceFlow id="Flow_09_commentReceived" sourceRef="UserTask_RespondComment" targetRef="UserTask_SupportReview" />
    <bpmn:sequenceFlow id="Flow_10_timeout" sourceRef="BoundaryTimer_ResponseTimeout" targetRef="UserTask_SupportReview" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="UserTask_SupportReview" targetRef="ExclusiveGateway_ApprovePenalty" />
    <bpmn:sequenceFlow id="Flow_12_yes" sourceRef="ExclusiveGateway_ApprovePenalty" targetRef="ServiceTask_ApplyPenalty">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approvePenalty == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_12_no" sourceRef="ExclusiveGateway_ApprovePenalty" targetRef="ServiceTask_CloseWithoutPenalty">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approvePenalty == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_13" sourceRef="ServiceTask_ApplyPenalty" targetRef="IntermediateThrowEvent_NotifyDecision" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="ServiceTask_CloseWithoutPenalty" targetRef="IntermediateThrowEvent_NotifyDecision" />
    <bpmn:sequenceFlow id="Flow_15_penalty" sourceRef="IntermediateThrowEvent_NotifyDecision" targetRef="EndEvent_PenaltyApplied">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${penaltyApplied == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_15_reject" sourceRef="IntermediateThrowEvent_NotifyDecision" targetRef="EndEvent_ClaimRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${penaltyApplied == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:intermediateCatchEvent id="BoundaryTimer_ResponseTimeout" name="Истек срок ответа">
      <bpmn:incoming>Flow_0cyfudy</bpmn:incoming>
      <bpmn:outgoing>Flow_10_timeout</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1ho3e18">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_0cyfudy" sourceRef="UserTask_RespondComment" targetRef="BoundaryTimer_ResponseTimeout" />
    <bpmn:userTask id="Activity_0gw4i7b" name="Проверка правил и оценка ущерба" camunda:assignee="${initiator}">
      <bpmn:documentation>Если данных недостаточно — запросить уточнение / дополнительные документы.</bpmn:documentation>
      <bpmn:incoming>Flow_04_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_065q47c</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_065q47c" sourceRef="Activity_0gw4i7b" targetRef="ExclusiveGateway_RulesViolated" />
    <bpmn:userTask id="Activity_1p30r0x" name="Проверить полноту и формат данных (вложение ущерба)" camunda:assignee="${initiator}">
      <bpmn:documentation>Если данных недостаточно — запросить уточнение / дополнительные документы.</bpmn:documentation>
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_1mbnhfb</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_05" sourceRef="UserTask_ProvideDocs" targetRef="Activity_1p30r0x" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="UserTask_CreateClaim" targetRef="Activity_1p30r0x" />
    <bpmn:sequenceFlow id="Flow_1mbnhfb" sourceRef="Activity_1p30r0x" targetRef="ExclusiveGateway_EnoughData" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_PenaltyClaimProcess">
    <bpmndi:BPMNPlane id="BPMNPlane_PenaltyClaimProcess" bpmnElement="PenaltyClaimProcess">
      <bpmndi:BPMNShape id="Lane_Respondent_di" bpmnElement="Lane_Respondent" isHorizontal="true">
        <dc:Bounds x="120" y="480" width="2310" height="180" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Platform_di" bpmnElement="Lane_Platform" isHorizontal="true">
        <dc:Bounds x="120" y="260" width="2310" height="220" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Client_di" bpmnElement="Lane_Client" isHorizontal="true">
        <dc:Bounds x="120" y="80" width="2310" height="180" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_RequestCreated_di" bpmnElement="StartEvent_RequestCreated">
        <dc:Bounds x="180" y="145" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_CreateClaim_di" bpmnElement="UserTask_CreateClaim">
        <dc:Bounds x="260" y="120" width="170" height="86" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ExclusiveGateway_EnoughData_di" bpmnElement="ExclusiveGateway_EnoughData" isMarkerVisible="true">
        <dc:Bounds x="735" y="345" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_ProvideDocs_di" bpmnElement="UserTask_ProvideDocs">
        <dc:Bounds x="840" y="120" width="190" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ExclusiveGateway_RulesViolated_di" bpmnElement="ExclusiveGateway_RulesViolated" isMarkerVisible="true">
        <dc:Bounds x="1090" y="345" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1075" y="316" width="81" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="IntermediateThrowEvent_RequestComment_di" bpmnElement="IntermediateThrowEvent_RequestComment">
        <dc:Bounds x="1210" y="552" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_RespondComment_di" bpmnElement="UserTask_RespondComment">
        <dc:Bounds x="1290" y="527" width="220" height="86" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_SupportReview_di" bpmnElement="UserTask_SupportReview">
        <dc:Bounds x="1570" y="327" width="220" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ExclusiveGateway_ApprovePenalty_di" bpmnElement="ExclusiveGateway_ApprovePenalty" isMarkerVisible="true">
        <dc:Bounds x="1850" y="345" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1838" y="316" width="74" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_ApplyPenalty_di" bpmnElement="ServiceTask_ApplyPenalty">
        <dc:Bounds x="1960" y="277" width="220" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_CloseWithoutPenalty_di" bpmnElement="ServiceTask_CloseWithoutPenalty">
        <dc:Bounds x="1960" y="377" width="220" height="86" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="IntermediateThrowEvent_NotifyDecision_di" bpmnElement="IntermediateThrowEvent_NotifyDecision">
        <dc:Bounds x="2250" y="145" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2240" y="95" width="55" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_PenaltyApplied_di" bpmnElement="EndEvent_PenaltyApplied">
        <dc:Bounds x="2340" y="125" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ClaimRejected_di" bpmnElement="EndEvent_ClaimRejected">
        <dc:Bounds x="2340" y="190" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_1p6urv1_di" bpmnElement="BoundaryTimer_ResponseTimeout">
        <dc:Bounds x="1592" y="552" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1583" y="588" width="55" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_0zbkpni" bpmnElement="Activity_0gw4i7b">
        <dc:Bounds x="840" y="327" width="190" height="86" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_0ic3bxf" bpmnElement="Activity_1p30r0x">
        <dc:Bounds x="495" y="327" width="190" height="86" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_01_di" bpmnElement="Flow_01">
        <di:waypoint x="216" y="163" />
        <di:waypoint x="260" y="163" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_04_yes_di" bpmnElement="Flow_04_yes">
        <di:waypoint x="785" y="370" />
        <di:waypoint x="840" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_04_no_di" bpmnElement="Flow_04_no">
        <di:waypoint x="760" y="345" />
        <di:waypoint x="760" y="163" />
        <di:waypoint x="840" y="163" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="769" y="251" width="13" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_07_yes_di" bpmnElement="Flow_07_yes">
        <di:waypoint x="1140" y="370" />
        <di:waypoint x="1228" y="370" />
        <di:waypoint x="1228" y="552" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_07_no_di" bpmnElement="Flow_07_no">
        <di:waypoint x="1115" y="395" />
        <di:waypoint x="1115" y="420" />
        <di:waypoint x="1960" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_08_di" bpmnElement="Flow_08">
        <di:waypoint x="1246" y="570" />
        <di:waypoint x="1290" y="570" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_09_commentReceived_di" bpmnElement="Flow_09_commentReceived">
        <di:waypoint x="1510" y="570" />
        <di:waypoint x="1540" y="570" />
        <di:waypoint x="1540" y="370" />
        <di:waypoint x="1570" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10_timeout_di" bpmnElement="Flow_10_timeout">
        <di:waypoint x="1610" y="552" />
        <di:waypoint x="1610" y="413" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1790" y="370" />
        <di:waypoint x="1850" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_12_yes_di" bpmnElement="Flow_12_yes">
        <di:waypoint x="1890" y="360" />
        <di:waypoint x="1930" y="360" />
        <di:waypoint x="1930" y="320" />
        <di:waypoint x="1960" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_12_no_di" bpmnElement="Flow_12_no">
        <di:waypoint x="1900" y="370" />
        <di:waypoint x="1930" y="370" />
        <di:waypoint x="1930" y="402" />
        <di:waypoint x="1960" y="402" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="2180" y="320" />
        <di:waypoint x="2268" y="320" />
        <di:waypoint x="2269" y="181" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="2180" y="420" />
        <di:waypoint x="2220" y="420" />
        <di:waypoint x="2220" y="163" />
        <di:waypoint x="2250" y="163" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_15_penalty_di" bpmnElement="Flow_15_penalty">
        <di:waypoint x="2286" y="163" />
        <di:waypoint x="2340" y="143" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_15_reject_di" bpmnElement="Flow_15_reject">
        <di:waypoint x="2286" y="163" />
        <di:waypoint x="2310" y="163" />
        <di:waypoint x="2310" y="208" />
        <di:waypoint x="2340" y="208" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0cyfudy_di" bpmnElement="Flow_0cyfudy">
        <di:waypoint x="1510" y="570" />
        <di:waypoint x="1592" y="570" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_065q47c_di" bpmnElement="Flow_065q47c">
        <di:waypoint x="1030" y="370" />
        <di:waypoint x="1090" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_05_di" bpmnElement="Flow_05">
        <di:waypoint x="1030" y="163" />
        <di:waypoint x="1080" y="163" />
        <di:waypoint x="1080" y="280" />
        <di:waypoint x="580" y="280" />
        <di:waypoint x="580" y="327" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_02_di" bpmnElement="Flow_02">
        <di:waypoint x="430" y="163" />
        <di:waypoint x="465" y="163" />
        <di:waypoint x="465" y="370" />
        <di:waypoint x="490" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1mbnhfb_di" bpmnElement="Flow_1mbnhfb">
        <di:waypoint x="685" y="370" />
        <di:waypoint x="735" y="370" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
